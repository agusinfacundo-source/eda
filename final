import pandas as pd 
import matplotlib.pyplot as plt 
import seaborn as sns

dataframe = pd.read_csv("social_media_user_behavior.csv")

dataframe.rename(columns={"gender":"genero", 
"age": "edad",
"profession" : "profesion",
"daily_usage_hours":"uso_diario",
"self_reported_mental_health_score":"salud_mental",
"primary_platform":"plataforma",
"sessions_per_day":"sesion_por_dia",
"preferred_device":"dispositivo_preferido",
"avg_session_duration_min":"duracion_promedio_de_sesion",
"followers_count":"cantidad_de_seguidores",
"following_count":"cantidad_de_seguidos",
"posts_per_week":"publicaciones_por_semana",
"likes_given_per_day":"likes_por_dia",
"comments_per_day":"comentarios_por_dia",
"shares_per_day":"compartidos_por_dia",
"dms_sent_per_day":"mensajes_privados_por_dia",
"ad_click_rate":"tasa_de_clicks_en_anuncios",
"monthly_spend_via_social_usd":"gasto_mensual_en_redes",
}, inplace=True)

print(dataframe.head())
print(dataframe.dtypes)

print(dataframe.isnull().sum())


print(dataframe["edad"].min())
print(dataframe["edad"].max())

print(dataframe.groupby('genero')['edad'].mean())

sns.boxplot(data=dataframe,x="genero",y="edad")
plt.savefig("edades.jpg") 
plt.show() 

plt.clf()

print(dataframe["edad"].describe())

print(dataframe["profesion"].value_counts())

print(dataframe.groupby("profesion")["uso_diario"].agg(["mean"]))


sns.boxplot(data=dataframe,x="profesion",y="uso_diario")
plt.savefig("relacion.jpg") 
plt.show()

plt.clf()

print(dataframe["uso_diario"].describe())

print(dataframe["salud_mental"].describe())


sns.scatterplot(data=dataframe,x="uso_diario",y="salud_mental")
plt.savefig("relacion2.jpg") 
plt.show()

plt.clf()


print(dataframe.groupby("genero")[["uso_diario", "salud_mental"]].mean())


print(dataframe.groupby("profesion")["salud_mental"].mean())

print(dataframe["plataforma"].value_counts())

print(dataframe.groupby("plataforma")["uso_diario"].mean())

print(dataframe.groupby("plataforma")["sesion_por_dia"].mean())

sns.barplot(data=dataframe, x="plataforma",y="sesion_por_dia")
plt.savefig("relacion3.jpg")
plt.show()


plt.clf()

sns.barplot( data=dataframe,x="plataforma",y="uso_diario",hue="genero")
plt.savefig("relacion4.jpg")
plt.show()

plt.clf()

print(dataframe["dispositivo_preferido"].value_counts(normalize=True))

sns.countplot(data=dataframe,x="dispositivo_preferido")

plt.savefig("muestra1.jpg")
plt.show()

plt.clf()


print(dataframe.groupby("dispositivo_preferido")["uso_diario"].mean())

corr = dataframe.corr(numeric_only=True)

sns.heatmap(corr, annot=True, cmap="coolwarm")

plt.savefig("heatmap.jpg")

plt.show()

plt.clf()
